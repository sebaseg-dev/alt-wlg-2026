---
import type { EnrichedDay } from '../../types/timetable';
import Layout from '../../layouts/Layout.astro';
import { enrichTimetableData } from '../../utils/enrichTimetableData';
import TimetableGrid from '../../components/TimetableGrid.astro';


export function getStaticPaths() {
    const data = enrichTimetableData();
    
    return data.map(day => ({
        params: { date: day.date },
        props: { initialData: day }
    }))
}

interface Props {
    initialData: EnrichedDay;
}

const { initialData } = Astro.props;
---
<Layout title={`${initialData.label}`}>
    <TimetableGrid dayData={initialData} />
</Layout>