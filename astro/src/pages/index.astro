---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import { flattenEventsData } from '../utils/flattenEventsData';

const allEvents = flattenEventsData();
let lastRenderedDate = "";
---

<Layout title="lineup">
    <div id="install-banner" class="install-card" style="display: none;">
        <div id="android-prompt" style="margin: 8px; display: none;">
            <h2>Installer l'application</h2>
            <p>Accédez aux horaires même sans réseau au milieu du festival !</p>
            <button id="install-button">Installer</button>
        </div>
        <div id="ios-prompt" style="margin: 8px; display: none;">
            <h2>Installer l'application</h2>
            <p>Appuyez sur le bouton <strong>Partager</strong> et choisissez <strong>"Sur l'écran d'accueil"</strong>.</p>
        </div>
    </div>
    
    <div class="scrollable-content">
        {allEvents.map((event) => {
            const newDay = event.date !== lastRenderedDate;
            lastRenderedDate = event.date;
            
            return <>
                {newDay && <h2>{event.dateLabel}</h2>}
                <EventCard event={event} />
            </>
        })}
    </div>
    
    <script is:inline>
        let deferredPrompt;
        const banner = document.getElementById('install-banner');
        const androidPrompt = document.getElementById('android-prompt');
        const iosPrompt = document.getElementById('ios-prompt');
        const installBtn = document.getElementById('install-button');
    
        // 1. Détection de l'état "Déjà installé"
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
    
        if (!isStandalone) {
            // 2. Détection iOS
            const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    
            if (isIOS) {
                // Sur iOS : on affiche directement les instructions
                banner.style.display = 'block';
                iosPrompt.style.display = 'block';
            } else {
                // Sur Android/Chrome : on attend l'événement système
                window.addEventListener('beforeinstallprompt', (e) => {
                    e.preventDefault();
                    deferredPrompt = e;
                    banner.style.display = 'block';
                    androidPrompt.style.display = 'block';
                });
            }
        }
    
        // 3. Gestion du clic sur le bouton Android
        if (installBtn) {
            installBtn.addEventListener('click', async () => {
                if (!deferredPrompt) return;
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                if (outcome === 'accepted') {
                    banner.style.display = 'none';
                }
                deferredPrompt = null;
            });
        }
        
        // 4. On cache si l'installation réussit
        window.addEventListener('appinstalled', () => {
            banner.style.display = 'none';
        });
    </script>
</Layout>

<style>
    .install-card {
        background-color: var(--appBackgroundColor);
        color: var(--lightTextColor);
        border-radius: 8px;

        & h2, p {
            margin: 0;
            margin-bottom: 8px;
        }
    }

    #install-button {
        display: block;
        margin-left: auto;
        border: none;
        border-radius: 8px;
        background-color: var(--bodyBackgroundColor);
        color: var(--textColor);
        padding: 4px 8px;
    }
</style>