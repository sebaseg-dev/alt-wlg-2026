---
import type { EnrichedTimetableData, TimetableData } from '../types/timetable';
import Layout from '../layouts/Layout.astro';
import rawData from '../data/data.json';
import { enrichTimetableData } from '../utils/enrichTimetableData';

const data: EnrichedTimetableData = enrichTimetableData(rawData as TimetableData);

const allArtists = data.flatMap(day => 
    day.scenes.flatMap((scene, sceneIndex) => 
        scene.lineup.map(event => ({
            ...event,
            sceneName: scene.name,
            sceneIndex: sceneIndex,
            date: day.date,
            dateLabel: day.label,
        }))
    )
);

allArtists.sort((a, b) => {
    if (a.date !== b.date){
        return a.date.localeCompare(b.date);
    }

    if (a.startDecimal !== b.startDecimal){
        return a.startDecimal - b.startDecimal;
    }

    return a.sceneIndex - b.sceneIndex;
})

let lastRenderedDate = "";
---

<Layout title="lineup">

    <div class="scrollable-content">
        {allArtists.map((artist) => {
            const newDay = artist.date !== lastRenderedDate;
            lastRenderedDate = artist.date;
            
            return <>
                {newDay && <h2>{artist.dateLabel}</h2>}
                <div class="test">{artist.date} {artist.startDecimal} {artist.sceneIndex}</div>
            </>
        })}
    </div>
    

    <script is:inline>
        // Écoute l'événement beforeinstallprompt (nécessaire pour l'installation)
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            // Empêche Chrome de masquer automatiquement le prompt
            e.preventDefault();
            // Stocke l'événement pour plus tard
            deferredPrompt = e;
            console.log('📱 PWA installable ! beforeinstallprompt déclenché.');
        
            // Affiche un bouton manuel pour tester (optionnel)
            const installButton = document.createElement('button');
            installButton.textContent = 'Installer l\'app';
            installButton.style.position = 'fixed';
            installButton.style.bottom = '20px';
            installButton.style.right = '20px';
            installButton.style.zIndex = '9999';
            installButton.addEventListener('click', () => {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        console.log('🎉 Utilisateur a accepté l\'installation !');
                    } else {
                        console.log('❌ Utilisateur a refusé l\'installation.');
                    }
                    deferredPrompt = null;
                });
            });
            document.body.appendChild(installButton);
        });
        
        // Vérifie si l'app est déjà installée
        window.addEventListener('appinstalled', (evt) => {
            console.log('✅ App installée avec succès !');
        });
    </script>
</Layout>

<style>
    .scrollable-content {
        overflow-y: auto;
    }
</style>