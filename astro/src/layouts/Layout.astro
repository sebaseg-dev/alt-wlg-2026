---
import { COLORS } from "../constants";
import Header from "../components/Header.astro";
import NavBar from "../components/NavBar.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;

const { PUBLIC_UMAMI_WEBSITE_ID } = import.meta.env;

---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1", viewport-fit="cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="theme-color" content="#424242" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black">
        <meta name="apple-mobile-web-app-title" content="alt wlg 26">
		<link rel="apple-touch-icon" href="/icon-192x192.png" />
		{ PUBLIC_UMAMI_WEBSITE_ID && 
		    <script defer src="https://umami.sebaseg.fr/script.js" data-website-id={PUBLIC_UMAMI_WEBSITE_ID}></script> 
		}
	</head>
	<body>
	    <Header pageTitle={title} />
			<main>
			    <slot />
			</main>
		<NavBar />
	</body>
	<script is:inline src="/registerSW.js"></script>
</html>

<style is:global define:vars={{ 
    textColor: COLORS.DARK_POINT,
    lightTextColor: COLORS.LIGHT_POINT,
    appBackgroundColor: COLORS.DARK_POINT,
    bodyBackgroundColor: COLORS.LIGHT_POINT,
    accentColor: COLORS.ACCENT,
    scene0PlainColor: COLORS.SCENE_0_PLAIN,
    scene1PlainColor: COLORS.SCENE_1_PLAIN,
    scene2PlainColor: COLORS.SCENE_2_PLAIN,
    scene3PlainColor: COLORS.SCENE_3_PLAIN,
    scene4PlainColor: COLORS.SCENE_4_PLAIN,
}}>
	html { 
	    font-family: system-ui, sans-serif; 
		background: var(--appBackgroundColor); 
		color: var(--textColor); 
	}
	
	body { 
	    background-color: var(--bodyBackgroundColor);
	    margin: 0; 
		padding: 0;
	}

    main {
        padding: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        /* device view height (100dvh) - footer (4rem) - header (2*1.5rem*1.5)-(2*16px) - padding main (2*16px)*/
        height: calc(100dvh - 4rem - calc(2 * 1.5rem * 1.5) - 16px - 16px - 16px - 16px);
    }

    .scrollable-content {
        overflow-y: auto;
        scrollbar-width: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    
    a {
        color: inherit;
        text-decoration: inherit;
    }

    .scene-0 {
        --scene-color: var(--scene0PlainColor);
    }
    .scene-1 {
        --scene-color: var(--scene1PlainColor);
    }
    .scene-2 {
        --scene-color: var(--scene2PlainColor);
    }
    .scene-3 {
        --scene-color: var(--scene3PlainColor);
    }
    .scene-4 {
        --scene-color: var(--scene4PlainColor);
    }

</style>
