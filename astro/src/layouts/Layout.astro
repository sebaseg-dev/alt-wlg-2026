---
import { COLORS } from "../constants";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="theme-color" content="#111111" />
		<link rel="manifest" href="/manifest.webmanifest" />
	</head>
	<body>
		<slot />

		<script is:inline src="/registerSW.js"></script>
	</body>
</html>

<style is:global define:vars={{ 
    textColor: COLORS.DARK_POINT,
    backgroundColor: COLORS.LIGHT_POINT,
    accentColor: COLORS.ACCENT,
    scene0PlainColor: COLORS.SCENE_0_PLAIN,
    scene1PlainColor: COLORS.SCENE_1_PLAIN,
    scene2PlainColor: COLORS.SCENE_2_PLAIN,
    scene3PlainColor: COLORS.SCENE_3_PLAIN,
    scene4PlainColor: COLORS.SCENE_4_PLAIN,
}}>
	html { 
	    font-family: system-ui, sans-serif; 
		background: var(--backgroundColor); 
		color: var(--textColor); 
	}
	
	body { 
	    margin: 0; 
		padding: 16px; 
	}
</style>
