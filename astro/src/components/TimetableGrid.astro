---
import type { EnrichedDay } from '../types/timetable';
import decimalTimeToDisplayTime from '../utils/decimalTimeToDisplayTime';

interface Props {
	dayData: EnrichedDay;
}

const { dayData } = Astro.props;

const allDecimalTimes = dayData.scenes.flatMap(scene => scene.lineup.flatMap(event => [event.startDecimal, event.endDecimal]));

const hasEvents = allDecimalTimes.length > 0;

const minTime = hasEvents ? Math.min(...allDecimalTimes) : 12;
const openingTime = decimalTimeToDisplayTime(minTime);
const maxTime = hasEvents ? Math.max(...allDecimalTimes) : 12;
const closingTime = decimalTimeToDisplayTime(maxTime);
const totalQuarters = (maxTime - minTime) * 4;
const scenes = dayData.scenes.map(scene => scene.name);

---

<div class="general-hours">
    <div class="hours">
        <div>▶️</div>
        <div>{openingTime}</div>
    </div>
    <div class="hours">
        <div>⏹️</div>
        <div>{closingTime}</div>
    </div>
    <div class="hours">
        <div>Ⓜ️</div>
        <div>{dayData.last_metro}</div>
    </div>
</div>

<div class="timetable-wrapper">
    <div class="timetable-grid"style={`
            grid-template-columns: repeat(${scenes.length}, 140px); 
            grid-template-rows: repeat(${totalQuarters + 1}, 24px);
    `}>
        {dayData.scenes.map((scene, sceneIndex) => (
            <>
                <div class={`scene-header scene-${sceneIndex}`} style={`grid-column: ${sceneIndex + 1}`}>
                    {scene.name}
                </div>
            
                {scene.lineup.map((event, eventIndex) => (
                    <a href={`/event/${event.id}/`} class={`lineup-item scene-${sceneIndex} type-${event.type}`} style={`
                        grid-column: ${sceneIndex + 1};
                        grid-row: ${Math.round((event.startDecimal - minTime) * 4) + 2} / span ${Math.floor(event.durationQuarters)};
                    `}>
                            <span class="event-name">{event.artist}</span>
                            <span class="event-times">{event.start_time} - {event.end_time}</span>
                    </a>
                ))}
            </>
        ))}
    </div>
</div>

<style>
    a {
        display: block;
    }

    .general-hours {
        display: flex;
        justify-content: space-around;
        margin-bottom: 16px;

        & > .hours {
            display: flex;
            flex-direction: column;

            & > div {
                text-align: center;
            }
        }
    }
    
    .timetable-wrapper {
        flex: 1;
        position: relative;
        width: 100%;
        overflow: auto;
        -webkit-overflow-scrolling: touch;
    }

    .timetable-grid {
        display: grid;
        width: max-content;
    }

    .scene-header {
        text-wrap: nowrap;
        background-color: var(--textColor);
        color: color-mix(in srgb, var(--scene-color), white 40%);
        position: sticky;
        top: 0;
        z-index: 100;
        text-align: center;
        font-weight: 700;
        line-height: 1.5;
    }

    .lineup-item {
        &.type-music {
            background-color: color-mix(in srgb, var(--scene-color), transparent 80%);
            box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05); 
        }

        &.type-talk {
            background-color: color-mix(in srgb, var(--scene-color), transparent 94%);
            box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--scene-color), transparent 60%);
        }
        
        border-radius: 8px;
        padding: 8px;
        display: flex;
        flex-direction: column;
        flex-wrap: nowrap;
        align-items: center;
        justify-content: center;
    }

    .event-name {
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: center;
        font-weight: 600;
        flex-shrink: 0;
        line-height: 1.2rem;
        max-height: round(down, 50%, 1.2rem);  
        min-height: 1.2rem;
        overflow: hidden;
    }
</style>
