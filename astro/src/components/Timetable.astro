---
// Props : optionnel, tu peux passer des données directement si tu veux un rendu côté serveur
// Mais ici on va tout gérer côté client pour la PWA
---

<div id="timetable-container">
  <div id="offline-indicator" style="display: none; background: #ff5252; color: white; padding: 10px; text-align: center; position: fixed; top: 0; left: 0; right: 0; z-index: 1000;">
    ⚠️ Mode hors ligne - Données en cache
  </div>
  <div id="timetable"><p style="text-align: center; padding: 40px; color: #aaa;">Chargement en cours...</p></div>
</div>

<script is:inline>
  // Fonction pour charger les données depuis le cache du SW
  async function fetchFromCache(url) {
    try {
      const cache = await caches.open('data-cache-v1'); // Utilise le nom de cache de ta config Workbox
      const cachedResponse = await cache.match(url);
      if (cachedResponse) {
        return await cachedResponse.json();
      }
    } catch (error) {
      console.error('Erreur lors de la lecture du cache:', error);
    }
    return null;
  }

  // Fonction pour afficher le timetable
  function renderTimetable(data) {
    const container = document.getElementById('timetable');
    if (!data || data.length === 0) {
      container.innerHTML = '<p style="text-align: center; padding: 40px; color: #aaa;">Aucune donnée disponible.</p>';
      return;
    }

    container.innerHTML = data.map(day => `
      <div class="day-container" style="margin-bottom: 40px; border-bottom: 1px solid #444; padding-bottom: 20px;">
        <div class="day-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
          <div class="day-label" style="font-size: 1.5rem; font-weight: bold;">${day.label}</div>
          <div class="last-metro" style="font-size: 0.9rem; color: #aaa; font-style: italic;">Dernier métro: ${day.last_metro}</div>
        </div>
        ${day.scenes.map(scene => `
          <div class="scene" style="margin-bottom: 25px; background: #222; border-radius: 8px; padding: 15px;">
            <div class="scene-name" style="font-size: 1.2rem; font-weight: bold; margin-bottom: 10px; color: #4CAF50; border-bottom: 1px solid #444; padding-bottom: 5px;">${scene.name}</div>
            ${scene.lineup.map(event => `
              <div class="event" style="display: flex; justify-content: space-between; padding: 8px 12px; margin: 5px 0; background: #333; border-radius: 4px;">
                <span class="time" style="color: #aaa; font-size: 0.9rem;">${event.start_time} - ${event.end_time}</span>
                <span class="artist" style="font-weight: bold;">${event.artist}</span>
              </div>
            `).join('')}
          </div>
        `).join('')}
      </div>
    `).join('');
  }

  // Charge les données
  async function loadData() {
    try {
      console.log('🔍 Tentative de chargement de /data.json (réseau)...');
      const response = await fetch('/data.json');

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const data = await response.json();
      console.log('✅ Données chargées depuis le réseau');
      renderTimetable(data);
      localStorage.setItem('timetableData', JSON.stringify(data));
    } catch (error) {
      console.error('❌ Échec du chargement depuis le réseau:', error);

      // 1. Essaie de charger depuis le cache du SW
      console.log('🔍 Tentative de chargement depuis le cache SW...');
      const cachedData = await fetchFromCache('/data.json');
      if (cachedData) {
        console.log('✅ Données chargées depuis le cache SW');
        renderTimetable(cachedData);
        localStorage.setItem('timetableData', JSON.stringify(cachedData));
        return;
      }

      // 2. Essaie localStorage
      console.log('🔍 Tentative de chargement depuis localStorage...');
      const storedData = localStorage.getItem('timetableData');
      if (storedData) {
        console.log('⚠️ Données chargées depuis localStorage');
        renderTimetable(JSON.parse(storedData));
        return;
      }

      // 3. Aucune donnée disponible
      console.error('❌ Aucune donnée disponible (réseau, cache SW ou localStorage)');
      document.getElementById('timetable').innerHTML = '<p style="text-align: center; padding: 40px; color: #aaa;">Erreur : impossible de charger les données.</p>';
    }
  }

  // Écoute les changements de connexion
  window.addEventListener('online', () => {
    document.getElementById('offline-indicator').style.display = 'none';
    loadData(); // Recharge les données si la connexion revient
  });

  window.addEventListener('offline', () => {
    document.getElementById('offline-indicator').style.display = 'block';
  });

  // Vérifie la connexion au chargement
  if (!navigator.onLine) {
    document.getElementById('offline-indicator').style.display = 'block';
  }

  // Charge les données au démarrage
  loadData();
</script>

<style>
  /* Styles spécifiques au composant */
  .day-container {
    margin-bottom: 40px;
    border-bottom: 1px solid #444;
    padding-bottom: 20px;
  }
  .day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
  }
  .day-label {
    font-size: 1.5rem;
    font-weight: bold;
  }
  .last-metro {
    font-size: 0.9rem;
    color: #aaa;
    font-style: italic;
  }
  .scene {
    margin-bottom: 25px;
    background: #222;
    border-radius: 8px;
    padding: 15px;
  }
  .scene-name {
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 10px;
    color: #4CAF50;
    border-bottom: 1px solid #444;
    padding-bottom: 5px;
  }
  .event {
    display: flex;
    justify-content: space-between;
    padding: 8px 12px;
    margin: 5px 0;
    background: #333;
    border-radius: 4px;
  }
  .time {
    color: #aaa;
    font-size: 0.9rem;
  }
  .artist {
    font-weight: bold;
  }
</style>