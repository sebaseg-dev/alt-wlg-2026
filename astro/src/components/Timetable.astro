---
// Props : optionnel, tu peux passer des données directement si tu veux un rendu côté serveur
// Mais ici on gère le chargement et le rafraîchissement dynamique côté client pour la PWA
---

<div id="timetable-container">
  <div id="offline-indicator">
    ⚠️ Mode hors ligne - Données locales (les mises à jour reprendront au retour du réseau)
  </div>
  
  <div id="timetable">
    <p class="loading">Chargement du line-up en cours...</p>
  </div>
</div>

<script>
  // 1. Importation du nouveau service optimisé
  import { getTimetableData } from '../data/dataService';

  // Sélection des éléments du DOM indispensables
  const timetableEl = document.getElementById('timetable');
  const offlineIndicatorEl = document.getElementById('offline-indicator');

  /**
   * Fonction de rendu HTML (Génère la structure propre à partir du JSON)
   */
  function renderTimetable(data) {
    if (!timetableEl) return;
    
    if (!data || data.length === 0) {
      timetableEl.innerHTML = '<p class="error">Aucune donnée disponible pour le moment.</p>';
      return;
    }

    timetableEl.innerHTML = data.map(day => `
      <div class="day-container">
        <div class="day-header">
          <div class="day-label">${day.label}</div>
          <div class="last-metro">Dernier métro : ${day.last_metro}</div>
        </div>
        ${day.scenes.map(scene => `
          <div class="scene">
            <div class="scene-name">${scene.name}</div>
            ${scene.lineup.map(event => `
              <div class="event" data-type="${event.type}">
                <span class="time">${event.start_time} - ${event.end_time}</span>
                <span class="artist">${event.artist} ${event.type === 'talk' ? '🗣️' : ''}</span>
              </div>
            `).join('')}
          </div>
        `).join('')}
      </div>
    `).join('');
  }

  /**
   * Initialisation et gestion du cycle de vie des données
   */
  async function init() {
    // Gestion de l'indicateur offline au démarrage
    toggleOfflineIndicator(!navigator.onLine);

    // On appelle notre service. 
    // On lui passe un callback (freshData) => { ... } : si le service découvre une mise à jour 
    // sur le réseau en arrière-plan, il appellera automatiquement cette fonction pour rafraîchir l'écran !
    const data = await getTimetableData((freshData) => {
      console.log('⚡ UI mise à jour de manière fluide avec les dernières modifications du serveur !');
      renderTimetable(freshData);
    });

    // Rendu initial (affiche immédiatement le cache ou le localStorage)
    renderTimetable(data);
  }

  /**
   * Gère l'affichage de la barre d'alerte hors-ligne
   */
  function toggleOfflineIndicator(isOffline) {
    if (offlineIndicatorEl) {
      offlineIndicatorEl.style.display = isOffline ? 'block' : 'none';
    }
  }

  // Écouteurs d'événements réseau standards du navigateur
  window.addEventListener('online', () => {
    toggleOfflineIndicator(false);
    init(); // Relance la machine pour revalider les données sur le réseau
  });

  window.addEventListener('offline', () => {
    toggleOfflineIndicator(true);
  });

  // Lancement du script au chargement de la page
  init();
</script>

<style>
  /* Styles spécifiques au composant */
  #offline-indicator {
    display: none;
    background: #ff9800; /* Orange pour être moins agressif qu'un rouge erreur */
    color: black;
    font-weight: bold;
    padding: 10px;
    text-align: center;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    font-size: 0.9rem;
  }

  .loading, .error {
    text-align: center;
    padding: 40px;
    color: #aaa;
  }

  .day-container {
    margin-bottom: 40px;
    border-bottom: 1px solid #444;
    padding-bottom: 20px;
  }
  .day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
  }
  .day-label {
    font-size: 1.5rem;
    font-weight: bold;
  }
  .last-metro {
    font-size: 0.9rem;
    color: #aaa;
    font-style: italic;
  }
  .scene {
    margin-bottom: 25px;
    background: #222;
    border-radius: 8px;
    padding: 15px;
  }
  .scene-name {
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 10px;
    color: #4CAF50;
    border-bottom: 1px solid #444;
    padding-bottom: 5px;
  }
  .event {
    display: flex;
    justify-content: space-between;
    padding: 8px 12px;
    margin: 5px 0;
    background: #333;
    border-radius: 4px;
    transition: background 0.2s;
  }
  
  /* Petit bonus UX : une couleur légèrement différente pour repérer les talks/conférences */
  .event[data-type="talk"] {
    border-left: 3px solid #00bcd4;
    background: #2a353d;
  }

  .time {
    color: #aaa;
    font-size: 0.9rem;
  }
  .artist {
    font-weight: bold;
  }
</style>